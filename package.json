{
  "name": "prio-queue-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "platform-dashboard",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\" \"npm --workspace platform-dashboard run dev\"",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:platform": "npm --workspace platform-dashboard run dev",
    "db:migrate": "bash scripts/db-apply.sh migrate",
    "db:bootstrap": "bash scripts/db-apply.sh bootstrap",
    "db:status": "bash scripts/db-status.sh",
    "db:verify": "bash scripts/db-verify-schema.sh",
    "oauth:smoke": "node scripts/oauth-smoke.mjs",
    "build": "npm --workspace frontend run build && npm --workspace platform-dashboard run build",
    "build:backend": "npm --workspace backend run build",
    "start": "npm --workspace backend run start",
    "smoke": "node scripts/smoke-test.mjs",
    "lint": "eslint backend/src frontend/src platform-dashboard/src shared",
    "lint:fix": "eslint backend/src frontend/src platform-dashboard/src shared --fix",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:platform && npm run typecheck:backend",
    "typecheck:frontend": "npm --workspace frontend run typecheck",
    "typecheck:platform": "npm --workspace platform-dashboard run typecheck",
    "typecheck:backend": "npm --workspace backend run typecheck",
    "test:frontend": "npm --workspace frontend run test",
    "test:frontend:coverage": "npm --workspace frontend run test:coverage",
    "test:backend": "npm --workspace backend run test",
    "test:backend:coverage": "npm --workspace backend run test:coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "backend/src/**/*.{js,ts}": [
      "eslint --fix"
    ],
    "frontend/src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "shared/**/*.ts": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "c8": "^10.1.3",
    "concurrently": "^9.2.3",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
